<!-- Admin Top Navbar (Mobile) -->
<nav class="bg-white border-b border-slate-200 py-4 px-6 flex justify-between items-center sticky top-0 z-[60] md:hidden">
    <div class="flex items-center gap-4">
        <button onclick="toggleAdminSidebar()" class="text-slate-600 text-xl">
            <i class="fas fa-bars"></i>
        </button>
        <h1 class="text-lg font-black italic tracking-tighter text-slate-900">SHAHAB <span class="text-blue-600">ADMIN</span></h1>
    </div>
    <a href="/logout" class="text-red-500 text-sm font-bold">LOGOUT</a>
</nav>

<!-- Mobile Sidebar Overlay -->
<div id="admin-sidebar-overlay" onclick="toggleAdminSidebar()" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-[70] hidden md:hidden"></div>

<!-- Sidebar (Desktop Fix / Mobile Toggle) -->
<aside id="admin-sidebar" class="fixed top-0 left-0 bottom-0 w-64 bg-slate-900 text-white z-[80] -translate-x-full md:translate-x-0 transition-transform duration-300 flex flex-col shadow-2xl">
    <div class="p-8 border-b border-white/5 flex justify-between items-center">
        <h1 class="text-xl font-black italic tracking-tighter">SHAHAB <span class="text-blue-500">ADMIN</span></h1>
        <button onclick="toggleAdminSidebar()" class="md:hidden text-white/50 text-2xl">&times;</button>
    </div>
    
    <nav class="flex-grow p-4 space-y-2 mt-4">
        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest ml-4 mb-4">Management</p>
        
        <a href="/admin/orders" class="flex items-center gap-4 p-4 rounded-2xl transition <%= activePath === '/admin/orders' ? 'bg-blue-600 font-bold shadow-lg shadow-blue-600/20' : 'hover:bg-white/5 text-slate-400' %>">
            <i class="fas fa-shopping-cart w-5"></i> Orders
            <% if (pendingOrdersCount > 0) { %>
                <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse ml-auto"></span>
            <% } %>
        </a>

        <a href="/admin/queries" class="flex items-center gap-4 p-4 rounded-2xl transition <%= activePath === '/admin/queries' ? 'bg-blue-600 font-bold shadow-lg shadow-blue-600/20' : 'hover:bg-white/5 text-slate-400' %>">
            <i class="fas fa-envelope w-5"></i> Queries
            <% if (pendingInquiriesCount > 0) { %>
                <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse ml-auto"></span>
            <% } %>
        </a>

        <a href="/admin" class="flex items-center gap-4 p-4 rounded-2xl transition <%= activePath === '/admin' ? 'bg-blue-600 font-bold shadow-lg shadow-blue-600/20' : 'hover:bg-white/5 text-slate-400' %>">
            <i class="fas fa-boxes w-5"></i> Inventory
        </a>
        
        <a href="/admin/settings" class="flex items-center gap-4 p-4 rounded-2xl transition <%= activePath === '/admin/settings' ? 'bg-blue-600 font-bold shadow-lg shadow-blue-600/20' : 'hover:bg-white/5 text-slate-400' %>">
            <i class="fas fa-cog w-5"></i> Site Settings
        </a>

        <div class="pt-4 mt-4 border-t border-white/5">
            <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest ml-4 mb-4">System</p>
            <a href="/" class="flex items-center gap-4 p-4 rounded-2xl hover:bg-white/5 text-slate-400 transition">
                <i class="fas fa-external-link-alt w-5"></i> View Website
            </a>
            <a href="/logout" class="flex items-center gap-4 p-4 rounded-2xl hover:bg-red-500/10 text-red-400 transition">
                <i class="fas fa-sign-out-alt w-5"></i> Logout
            </a>
        </div>
    </nav>

    <div class="p-6 border-t border-white/5 bg-black/20">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center font-bold text-xs">S</div>
            <div class="text-xs">
                <p class="font-bold">Shahab Mobile</p>
                <p class="text-slate-500">Super Admin</p>
            </div>
        </div>
    </div>
</aside>

<script>
    function toggleAdminSidebar() {
        const sidebar = document.getElementById('admin-sidebar');
        const overlay = document.getElementById('admin-sidebar-overlay');
        sidebar.classList.toggle('-translate-x-full');
        overlay.classList.toggle('hidden');
    }
</script>