<!DOCTYPE html>
<html lang="en">
<head>
    <title><%= title %></title>
    <%- include('head') %>
</head>
<body class="bg-slate-100 min-h-screen flex items-center justify-center p-4">
    <div class="max-w-md w-full bg-white rounded-[2.5rem] p-8 md:p-12 shadow-xl border border-slate-100">
        <div class="text-center mb-10">
            <h1 class="text-3xl font-black text-slate-900 mb-2">Admin Login</h1>
            <p class="text-slate-500">Sirf authorized access ke liye.</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-50 text-red-600 p-4 rounded-2xl mb-6 text-sm font-bold text-center border border-red-100">
                <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST" class="space-y-6">
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase mb-2 ml-2">Email Address</label>
                <input type="email" name="email" required placeholder="admin@example.com" class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase mb-2 ml-2">Password</label>
                <input type="password" name="password" required class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <button type="submit" class="w-full bg-slate-900 text-white py-5 rounded-3xl font-black text-lg hover:bg-slate-800 transition shadow-xl">
                LOG IN
            </button>
        </form>

        <div class="mt-8 text-center">
            <a href="/" class="text-slate-400 hover:text-blue-600 font-bold text-sm transition">Wapis Home Par Jayein</a>
        </div>
    </div>
</body>
</html>