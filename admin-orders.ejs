<!DOCTYPE html>
<html lang="en">
<head>
    <title><%= title %></title>
    <%- include('head') %>
</head>
<body class="bg-slate-100 min-h-screen flex">
    <%- include('admin-nav') %>
    <main class="flex-grow p-4 md:p-10 md:ml-64">
        <div class="mb-10">
            <h2 class="text-3xl font-black text-slate-800">Customer Orders</h2>
            <p class="text-slate-500">Manage sales and update delivery status.</p>
        </div>

        <div class="grid grid-cols-1 gap-6">
            <% orders.forEach(order => { %>
                <% 
                    let statusClass = 'bg-white';
                    if (order.status === 'Pending') statusClass = 'bg-orange-50/50';
                    else if (order.status === 'Packed') statusClass = 'bg-cyan-50/50';
                    else if (order.status === 'Ready for Delivery') statusClass = 'bg-indigo-50/50';
                    else if (order.status === 'Out for Delivery') statusClass = 'bg-amber-50/50';
                    else if (order.status === 'Shipped') statusClass = 'bg-green-50/50';
                    else if (order.status === 'Cancelled') statusClass = 'bg-red-50/50';
                %>
                <div class="<%= statusClass %> rounded-[2rem] p-5 md:p-6 shadow-sm border border-slate-200 flex flex-col md:flex-row justify-between gap-6 transition-colors duration-300">
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="text-xs font-black bg-blue-50 text-blue-600 px-3 py-1 rounded-full"><%= order.orderId %></span>
                            <% if (order.status === 'Shipped') { %>
                                <span class="text-[10px] font-black bg-red-600 text-white px-3 py-1 rounded-full shadow-lg shadow-red-200 uppercase flex items-center gap-1 animate-pulse">
                                    <i class="fas fa-check-circle text-[8px]"></i> Order Shipped
                                </span>
                            <% } %>
                            <span class="text-slate-400 text-xs"><%= new Date(order.createdAt).toLocaleString() %></span>
                        </div>
                        <h4 class="font-bold text-lg text-slate-800"><%= order.customerName %></h4>
                        <p class="text-slate-500 text-sm mb-2"><i class="fas fa-phone mr-2"></i> <%= order.customerPhone %></p>
                        <p class="text-slate-500 text-sm mb-4"><i class="fas fa-map-marker-alt mr-2"></i> <%= order.customerAddress %></p>
                        
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 pb-2">
                            <% order.items.forEach(item => { %>
                                <div class="bg-slate-50 p-2 rounded-xl flex items-center gap-3 border border-slate-100">
                                    <img src="<%= item.displayImage %>" class="w-10 h-10 object-contain rounded-lg bg-white border">
                                    <div class="flex flex-col">
                                        <span class="text-[11px] font-black text-slate-800"><%= item.name %></span>
                                        <span class="text-[10px] text-slate-500">Qty: <%= item.quantity %> | Rs. <%= item.price.toLocaleString() %></span>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <div class="flex flex-col justify-between items-stretch md:items-end gap-4 md:min-w-[200px]">
                        <div class="text-left md:text-right">
                            <p class="text-[10px] font-bold text-slate-400 uppercase">Total Bill</p>
                            <p class="text-xl font-black text-slate-900">Rs. <%= order.totalAmount.toLocaleString() %></p>
                            
                            <div class="mt-1">
                                <span class="text-[10px] font-bold px-3 py-1 rounded-full 
                                    <%= order.status === 'Shipped' ? 'bg-green-100 text-green-600' : 
                                        order.status === 'Cancelled' ? 'bg-red-100 text-red-600' : 
                                        order.status === 'Pending' ? 'bg-orange-100 text-orange-600' : 'bg-blue-100 text-blue-600' %>">
                                    <%= order.status %>
                                    <% if (order.status === 'Cancelled' && order.cancelledByCustomer) { %>
                                        <span class="ml-1 bg-red-600 text-white text-[8px] px-1.5 py-0.5 rounded uppercase">By Customer</span>
                                    <% } %>
                                </span>
                            </div>
                        </div>

                        <div class="w-full space-y-2">
                            <form action="/admin/order/update-status" method="POST" class="flex gap-2">
                                <input type="hidden" name="orderId" value="<%= order.orderId %>">
                                <select name="status" onchange="this.form.submit()" class="flex-grow bg-slate-50 border border-slate-200 p-3 rounded-xl text-xs font-bold outline-none focus:ring-2 focus:ring-blue-500">
                                    <% ['Pending', 'Packed', 'Ready for Delivery', 'Out for Delivery', 'Shipped', 'Cancelled'].forEach(s => { %>
                                        <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
                                    <% }) %>
                                </select>
                            </form>
                            
                            <div class="flex gap-2 w-full">
                                <form action="/admin/order/delete/<%= order.orderId %>" method="POST" class="flex-shrink-0" onsubmit="return confirm('Kya aap waqai ye order delete karna chahte hain?')">
                                    <button class="bg-red-50 text-red-600 p-3 rounded-xl hover:bg-red-600 hover:text-white transition">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            <% 
                               let trackUrl = `https://shahabmobile.com/track-order/${order.orderId}`; // Replace with your domain
                               let msg = `Asalam-o-Alaikum ${order.customerName}! Aapke Order (${order.orderId}) ka status update ho gaya hai: *${order.status}*. Aap yahan track kar sakte hain: ${trackUrl}`;
                            %>
                            <a href="https://wa.me/<%= order.customerPhone %>?text=<%= encodeURIComponent(msg) %>" target="_blank" class="flex-grow bg-green-500 text-white py-3 rounded-xl flex items-center justify-center gap-2 text-xs font-black hover:bg-green-600 transition">
                                <i class="fab fa-whatsapp text-sm"></i> NOTIFY CUSTOMER
                            </a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>

            <% if (orders.length === 0) { %>
                <div class="bg-white rounded-[2rem] p-20 text-center border-2 border-dashed border-slate-200">
                    <i class="fas fa-box-open text-5xl text-slate-200 mb-4"></i>
                    <p class="text-slate-400 font-bold">Abhi koi order nahi aaya.</p>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>