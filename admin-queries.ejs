<!DOCTYPE html>
<html lang="en">
<head>
    <title><%= title %></title>
    <%- include('head') %>
</head>
<body class="bg-slate-100 min-h-screen flex">
    <%- include('admin-nav') %>
    <main class="flex-grow flex md:ml-64 h-screen overflow-hidden">
        <!-- Sidebar: User List -->
        <div class="w-full md:w-80 bg-white border-r border-slate-200 flex flex-col">
            <div class="p-6 border-b border-slate-100">
                <h2 class="text-xl font-black text-slate-900">Inbox</h2>
            </div>
            <div class="flex-grow overflow-y-auto">
                <% userList.forEach(function(u) { %>
                    <a href="/admin/chat/<%= u._id %>" class="flex items-center gap-4 p-4 border-b border-slate-50 hover:bg-slate-50 transition <%= selectedUser && selectedUser._id.toString() === u._id.toString() ? 'bg-blue-50 border-l-4 border-l-blue-600' : '' %>">
                        <div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center font-bold text-slate-400 relative">
                            <%= u.fullName.charAt(0).toUpperCase() %>
                            <% if (u.latestInquiry && !u.latestInquiry.isReadByAdmin) { %>
                                <span class="absolute top-0 right-0 w-3 h-3 bg-red-500 border-2 border-white rounded-full"></span>
                            <% } %>
                        </div>
                        <div class="flex-grow min-w-0">
                            <div class="flex justify-between items-center mb-1">
                                <p class="text-sm font-black text-slate-800 truncate"><%= u.fullName %></p>
                                <span class="text-[8px] text-slate-400 uppercase font-bold"><%= u.latestInquiry ? new Date(u.latestInquiry.updatedAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) : '' %></span>
                            </div>
                            <p class="text-[10px] text-slate-500 truncate font-medium"><%= u.latestInquiry && u.latestInquiry.messages.length > 0 ? u.latestInquiry.messages[u.latestInquiry.messages.length - 1].text : 'No messages yet' %></p>
                        </div>
                    </a>
                <% }); %>
            </div>
        </div>

        <!-- Chat Area -->
        <div class="hidden md:flex flex-grow flex-col bg-slate-50 relative">
            <% if (selectedUser) { %>
                <!-- Chat Header -->
                <div class="bg-white p-4 border-b border-slate-200 flex justify-between items-center">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-sm"><%= selectedUser.fullName.charAt(0).toUpperCase() %></div>
                        <h3 class="font-black text-slate-900"><%= selectedUser.fullName %></h3>
                    </div>
                </div>

                <!-- Messages Box -->
                <div id="adminChatBox" class="flex-grow p-6 overflow-y-auto flex flex-col gap-6 bg-slate-50">
                    <% chat.forEach(function(thread) { %>
                        <div class="space-y-4">
                            <div class="text-center"><span class="text-[8px] font-black uppercase text-slate-400 bg-slate-200/50 px-2 py-1 rounded-full tracking-widest"><%= thread.subject %></span></div>
                            <% thread.messages.forEach(function(msg) { %>
                                <div class="flex <%= msg.sender === 'admin' ? 'justify-end' : 'justify-start' %>">
                                    <div class="max-w-[70%] p-4 rounded-[1.8rem] text-sm shadow-sm <%= msg.sender === 'admin' ? 'bg-slate-900 text-white rounded-tr-none' : 'bg-white text-slate-800 rounded-tl-none border border-slate-200' %>">
                                        <%= msg.text %>
                                        <p class="text-[8px] mt-1 opacity-50 text-right"><%= new Date(msg.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></p>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% }); %>
                </div>

                <!-- Input Area -->
                <div class="p-6 bg-white border-t border-slate-200">
                    <form action="/admin/query/respond" method="POST" class="flex gap-4">
                        <input type="hidden" name="inquiryId" value="<%= chat[chat.length - 1]._id %>">
                        <input type="text" name="adminResponse" placeholder="Apna reply yahan likhen..." class="flex-grow bg-slate-50 border border-slate-100 p-4 rounded-2xl outline-none focus:ring-2 focus:ring-blue-600" required>
                        <button type="submit" class="bg-blue-600 text-white w-14 h-14 rounded-2xl flex items-center justify-center shadow-lg shadow-blue-200 hover:bg-blue-700 transition">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </form>
                </div>
            <% } else { %>
                <div class="flex-grow flex items-center justify-center flex-col text-slate-300">
                    <div class="w-24 h-24 bg-white rounded-full flex items-center justify-center text-4xl shadow-sm border mb-4">
                        <i class="fas fa-comments"></i>
                    </div>
                    <p class="font-black text-slate-400 uppercase tracking-widest text-xs">Kisi customer ko select karein</p>
                </div>
            <% } %>
        </div>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const chatBox = document.getElementById('adminChatBox');
            if (chatBox) {
                chatBox.scrollTop = chatBox.scrollHeight;
            }

            let totalMessagesOnScreen = 0;
            <% chat.forEach(t => { %> totalMessagesOnScreen += <%= t.messages.length %>; <% }); %>

            // Real-time Polling for messages
            const selectedUserId = "<%= selectedUser ? selectedUser._id : '' %>";
            if (selectedUserId) {
                setInterval(async () => {
                    try {
                        const response = await fetch(`/api/admin/chat/messages/${selectedUserId}`);
                        const data = await response.json();

                        if (data.success && data.chat) {
                            let newMessagesCount = 0;
                            data.chat.forEach(thread => newMessagesCount += thread.messages.length);

                            if (newMessagesCount > totalMessagesOnScreen) {
                                totalMessagesOnScreen = newMessagesCount;
                                // In a more complex app, you'd append only new messages
                                const newChatHtml = data.chat.map(thread => `
                                    <div class="space-y-4">
                                        <div class="text-center"><span class="text-[8px] font-black uppercase text-slate-400 bg-slate-200/50 px-2 py-1 rounded-full tracking-widest">${thread.subject}</span></div>
                                        ${thread.messages.map(msg => `
                                            <div class="flex ${msg.sender === 'admin' ? 'justify-end' : 'justify-start'}">
                                                <div class="max-w-[70%] p-4 rounded-[1.8rem] text-sm shadow-sm ${msg.sender === 'admin' ? 'bg-slate-900 text-white rounded-tr-none' : 'bg-white text-slate-800 rounded-tl-none border border-slate-200'}">
                                                    ${msg.text}
                                                    <p class="text-[8px] mt-1 opacity-50 text-right">${new Date(msg.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</p>
                                                </div>
                                            </div>
                                        `).join('')}
                                    </div>
                                `).join('');
                                chatBox.innerHTML = newChatHtml;
                                chatBox.scrollTop = chatBox.scrollHeight; // Scroll to new message
                            }
                        }
                    } catch (error) {
                        console.error('Error fetching new messages for admin:', error);
                    }
                }, 3000); // Poll every 3 seconds
            }
        });
    </script>
</body>
</html>