<!DOCTYPE html>
<html lang="en">
<head>
    <title><%= title %></title>
    <%- include('head') %>
</head>
<body class="bg-slate-100 h-screen flex flex-col overflow-hidden">
    <%- include('nav') %>

    <main class="flex-grow flex container mx-auto md:px-4 py-6 overflow-hidden">
        <div class="bg-white w-full rounded-[2.5rem] shadow-2xl border border-slate-200 flex overflow-hidden">
            
            <!-- Sidebar: Inquiry Topics -->
            <div class="w-full md:w-80 border-r border-slate-100 flex flex-col <%= selectedChat ? 'hidden md:flex' : 'flex' %>">
                <div class="p-6 border-b border-slate-50 flex justify-between items-center">
                    <h2 class="text-xl font-black text-slate-900">Support Chats</h2>
                </div>
                <div class="flex-grow overflow-y-auto custom-scrollbar">
                    <a href="/chat" class="flex items-center gap-4 p-5 hover:bg-blue-50 transition border-b border-slate-50 bg-slate-50/50">
                        <div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center shadow-lg shadow-blue-200">
                            <i class="fas fa-plus"></i>
                        </div>
                        <span class="text-sm font-black text-blue-600">New Inquiry</span>
                    </a>
                    <% inquiries.forEach(function(q) { %>
                        <a href="/chat/<%= q._id %>" class="flex flex-col gap-1 p-5 border-b border-slate-50 hover:bg-slate-50 transition <%= selectedChat && selectedChat._id.toString() === q._id.toString() ? 'bg-blue-50 border-l-4 border-l-blue-600' : '' %>">
                            <div class="flex justify-between items-center">
                                <span class="text-[10px] font-black text-blue-600 uppercase tracking-widest"><%= q.subject %></span>
                                <% if (!q.isReadByCustomer) { %>
                                    <span class="w-2 h-2 bg-red-600 rounded-full animate-pulse"></span>
                                <% } %>
                            </div>
                            <p class="text-xs font-bold text-slate-800 truncate"><%= q.messages[q.messages.length - 1].text %></p>
                            <span class="text-[8px] text-slate-400 font-bold uppercase"><%= new Date(q.updatedAt).toLocaleDateString() %></span>
                        </a>
                    <% }); %>
                    <% if (inquiries.length === 0) { %>
                        <div class="p-10 text-center text-slate-400 text-sm italic">Koi puraani chat nahi mili.</div>
                    <% } %>
                </div>
            </div>

            <!-- Chat Area -->
            <div class="flex-grow flex flex-col bg-slate-50 relative <%= !selectedChat ? 'hidden md:flex' : 'flex' %>">
                <% if (selectedChat) { %>
                    <!-- Chat Header -->
                    <div class="bg-white p-5 border-b border-slate-100 flex items-center gap-4">
                        <a href="/chat" class="md:hidden text-slate-400 text-xl mr-2"><i class="fas fa-arrow-left"></i></a>
                        <div class="w-10 h-10 rounded-full bg-slate-900 text-white flex items-center justify-center font-bold text-sm">SM</div>
                        <div>
                            <h4 class="text-sm font-black text-slate-900">Shahab Mobile Support</h4>
                            <p class="text-[10px] font-bold text-blue-600 uppercase tracking-widest"><%= selectedChat.subject %></p>
                        </div>
                    </div>

                    <!-- Message Bubbles -->
                    <div id="chatBox" class="flex-grow p-6 overflow-y-auto flex flex-col gap-4 bg-[#efe7dd] scroll-smooth" style="background-image: url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png'); background-blend-mode: overlay;">
                        <% selectedChat.messages.forEach(function(msg) { %>
                            <div class="flex <%= msg.sender === 'customer' ? 'justify-end' : 'justify-start' %>">
                                <div class="max-w-[85%] p-4 rounded-[1.8rem] text-sm shadow-sm <%= msg.sender === 'customer' ? 'bg-[#dcf8c6] text-slate-800 rounded-tr-none' : 'bg-white text-slate-800 rounded-tl-none border border-slate-100' %>">
                                    <%= msg.text %>
                                    <p class="text-[9px] mt-1 opacity-50 text-right"><%= new Date(msg.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></p>
                                </div>
                            </div>
                        <% }); %>
                    </div>

                    <!-- Input Form -->
                    <form action="/chat/send" method="POST" class="p-6 bg-white border-t border-slate-100 flex gap-4">
                        <input type="hidden" name="subject" value="<%= selectedChat.subject %>">
                        <input type="text" name="message" placeholder="Type a message..." class="flex-grow bg-slate-50 border border-slate-200 px-6 py-4 rounded-2xl text-sm outline-none focus:ring-2 focus:ring-blue-600" required autofocus>
                        <button type="submit" class="bg-blue-600 text-white w-14 h-14 rounded-2xl flex items-center justify-center shadow-xl shadow-blue-200 hover:bg-blue-700 transition">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </form>

                <% } else { %>
                    <!-- New Chat Form -->
                    <div class="flex-grow flex flex-col items-center justify-center p-8 text-center bg-white overflow-y-auto">
                        <div class="max-w-md w-full my-auto">
                            <div class="w-24 h-24 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center text-4xl mx-auto mb-6">
                                <i class="fas fa-comment-medical"></i>
                            </div>
                            <h2 class="text-3xl font-black text-slate-900 mb-2">New Support Inquiry</h2>
                            <p class="text-slate-400 text-sm mb-8 font-bold uppercase tracking-widest">Start a conversation with our team</p>

                            <form action="/chat/send" method="POST" class="space-y-4 text-left">
                                <div>
                                    <label class="text-[10px] font-black text-slate-400 uppercase ml-2 mb-2 block">What is your query about?</label>
                                    <input type="text" id="subject" name="subject" placeholder="e.g., Delivery Status" class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl text-sm focus:ring-2 focus:ring-blue-600 outline-none" required>
                                </div>
                                <div>
                                    <label class="text-[10px] font-black text-slate-400 uppercase ml-2 mb-2 block">Message</label>
                                    <textarea name="message" placeholder="How can we help you?" rows="3" class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl text-sm focus:ring-2 focus:ring-blue-600 outline-none" required></textarea>
                                </div>
                                <button type="submit" class="w-full bg-blue-600 text-white py-5 rounded-2xl font-black text-sm hover:bg-blue-700 transition shadow-xl shadow-blue-200 mt-4">
                                    SEND MESSAGE
                                </button>
                            </form>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const subjectParam = urlParams.get('subject');
            const subjectField = document.getElementById('subject');
            if (subjectParam && subjectField) subjectField.value = subjectParam;

            const chatBox = document.getElementById('chatBox');
            const scrollToBottom = () => {
                if (chatBox) {
                    chatBox.scrollTop = chatBox.scrollHeight;
                }
            };
            
            scrollToBottom(); // Scroll on initial load

            // Real-time Polling for messages
            const selectedChatId = "<%= selectedChat ? selectedChat._id : '' %>";
            if (selectedChatId) {
                setInterval(async () => {
                    try {
                        const response = await fetch(`/api/chat/messages/${selectedChatId}`);
                        const data = await response.json();

                        if (data.success && data.messages) {
                            const currentMessagesCount = chatBox.children.length;
                            const newMessagesCount = data.messages.length;

                            if (newMessagesCount > currentMessagesCount) {
                                // New messages received, append them
                                const fragment = document.createDocumentFragment();
                                for (let i = currentMessagesCount; i < newMessagesCount; i++) {
                                    const msg = data.messages[i];
                                    const msgDiv = document.createElement('div');
                                    msgDiv.className = `flex ${msg.sender === 'customer' ? 'justify-end' : 'justify-start'}`;
                                    msgDiv.innerHTML = `
                                        <div class="max-w-[85%] p-4 rounded-[1.8rem] text-sm shadow-sm ${msg.sender === 'customer' ? 'bg-[#dcf8c6] text-slate-800 rounded-tr-none' : 'bg-white text-slate-800 rounded-tl-none border border-slate-100'}">
                                            ${msg.text}
                                            <p class="text-[9px] mt-1 opacity-50 text-right">${new Date(msg.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</p>
                                        </div>
                                    `;
                                    fragment.appendChild(msgDiv);
                                }
                                chatBox.appendChild(fragment);
                                scrollToBottom(); // Scroll to new message
                            }
                        }
                    } catch (error) {
                        console.error('Error fetching new messages:', error);
                    }
                }, 3000); // Poll every 3 seconds
            }
        });
    </script>
</body>
</html>