<% if (totalPages > 1) { %>
    <% 
       // Helper to keep existing query params when changing pages
       let currentUrl = baseUrl;
       // We replace the 'page' parameter if it exists
    %>
    <div class="flex justify-center items-center gap-2 mt-12 mb-8" id="server-pagination">
        <% if (currentPage > 1) { %>
            <% 
               let prevUrl = currentUrl + (currentUrl.includes('?') ? '&' : '?') + 'page=' + (currentPage - 1);
            %>
            <a href="<%= prevUrl %>" 
               class="w-10 h-10 flex items-center justify-center rounded-xl bg-white border border-slate-200 text-slate-500 hover:border-blue-600 transition shadow-sm">
                <i class="fas fa-chevron-left text-xs"></i>
            </a>
        <% } %>

        <% for(let i = 1; i <= totalPages; i++) { %>
            <% 
               let pageUrl = currentUrl + (currentUrl.includes('?') ? '&' : '?') + 'page=' + i;
            %>
            <a href="<%= pageUrl %>" 
               class="w-10 h-10 flex items-center justify-center rounded-xl font-bold transition shadow-sm <%= currentPage === i ? 'bg-blue-600 text-white shadow-blue-200' : 'bg-white border border-slate-200 text-slate-500 hover:border-blue-600' %>">
                <%= i %>
            </a>
        <% } %>

        <% if (currentPage < totalPages) { %>
            <% 
               let nextUrl = currentUrl + (currentUrl.includes('?') ? '&' : '?') + 'page=' + (currentPage + 1);
            %>
            <a href="<%= nextUrl %>" 
               class="w-10 h-10 flex items-center justify-center rounded-xl bg-white border border-slate-200 text-slate-500 hover:border-blue-600 transition shadow-sm">
                <i class="fas fa-chevron-right text-xs"></i>
            </a>
        <% } %>
    </div>
<% } %>