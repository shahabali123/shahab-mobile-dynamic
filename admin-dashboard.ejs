<!DOCTYPE html>
<html lang="en">
<head>
    <title>VIP Dashboard | Shahab Mobile</title>
    <%- include('head') %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-slate-100 flex min-h-screen">

    <%- include('admin-nav') %>

    <!-- Main Content (Adjusted padding for fixed sidebar) -->
    <main class="flex-grow p-4 md:p-10 md:ml-64 transition-all w-full">
        <!-- VIP Analytics Header -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10">
            <div class="bg-white p-8 rounded-[2.5rem] shadow-xl border border-slate-100">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="font-black text-slate-800 uppercase tracking-widest text-sm">Site Traffic</h3>
                    <span class="bg-green-100 text-green-600 px-3 py-1 rounded-full text-[10px] font-bold">LIVE VISITS: <%= stats.siteVisits %></span>
                </div>
                <canvas id="trafficChart" height="150"></canvas>
            </div>
            <div class="bg-white p-8 rounded-[2.5rem] shadow-xl border border-slate-100">
                <h3 class="font-black text-slate-800 uppercase tracking-widest text-sm mb-6">Top Trending Models</h3>
                <canvas id="trendingChart" height="150"></canvas>
            </div>
        </div>

        <!-- Search & Filters -->
        <div class="bg-white p-6 rounded-[2rem] shadow-lg border border-slate-100 mb-8">
            <form action="/admin" method="GET" class="flex flex-col md:flex-row gap-4 items-end">
                <div class="flex-grow">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase mb-2 ml-2">Search Product</label>
                    <div class="relative">
                            <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 z-10"></i>
                        <input type="text" name="search" value="<%= search %>" placeholder="Model name..." class="w-full bg-slate-50 border border-slate-100 pl-12 pr-4 py-3 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                </div>
                <div class="w-full md:w-48">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase mb-2 ml-2">Brand</label>
                    <select name="brand" class="w-full bg-slate-50 border border-slate-100 p-3 rounded-xl font-bold text-slate-700 outline-none">
                        <option value="">All Brands</option>
                        <% brands.forEach(b => { %>
                            <option value="<%= b %>" <%= selectedBrand === b ? 'selected' : '' %>><%= b %></option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit" class="bg-slate-900 text-white px-8 py-3 rounded-xl font-bold hover:bg-slate-800 transition">Filter</button>
                <a href="/admin" class="bg-slate-100 text-slate-500 px-4 py-3 rounded-xl font-bold hover:bg-slate-200 transition">Reset</a>
            </form>
        </div>

        <!-- Inventory Actions -->
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-2xl font-black text-slate-800">Inventory Management</h2>
            <a href="/admin/add" class="bg-blue-600 text-white px-6 py-3 rounded-xl font-bold shadow-lg shadow-blue-200 flex items-center gap-2">
                <i class="fas fa-plus"></i> Add Mobile
            </a>
        </div>

        <!-- Products Table -->
        <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm overflow-hidden mb-6">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-slate-50 border-b border-slate-100">
                        <tr>
                            <th class="p-6 font-bold text-slate-400 text-xs uppercase">Product</th>
                            <th class="p-6 font-bold text-slate-400 text-xs uppercase">Views</th>
                            <th class="p-6 font-bold text-slate-400 text-xs uppercase">Price</th>
                            <th class="p-6 font-bold text-slate-400 text-xs uppercase text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        <% products.forEach(p => { %>
                            <tr class="hover:bg-slate-50/50 transition">
                                <td class="p-6">
                                    <div class="flex items-center gap-4">
                                        <img src="<%= p.images[0] %>" class="w-10 h-10 rounded-lg object-contain bg-slate-100">
                                        <div>
                                            <p class="font-bold text-slate-800 text-sm"><%= p.name %></p>
                                            <span class="text-[9px] font-bold text-blue-600 uppercase"><%= p.brand %></span>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-6">
                                    <div class="flex items-center gap-2 text-slate-500 font-bold text-sm">
                                        <i class="fas fa-eye text-blue-400 text-xs"></i> <%= p.views || 0 %>
                                    </div>
                                </td>
                                <td class="p-6 font-bold text-slate-900 text-sm">Rs. <%= p.price.toLocaleString() %></td>
                                <td class="p-6 text-right space-x-3">
                                    <a href="/admin/edit/<%= p.id %>" class="text-blue-600 hover:underline font-bold text-xs">Edit</a>
                                    <form action="/admin/delete/<%= p.id %>" method="POST" class="inline" onsubmit="return confirm('Delete this product?')">
                                        <button class="text-red-400 hover:text-red-600 font-bold text-xs">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Stats Grid (Optional Quick View) -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-100 text-center"><p class="text-[10px] text-slate-400 font-bold uppercase">Total Models</p><p class="font-black text-xl"><%= stats.total %></p></div>
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-100 text-center"><p class="text-[10px] text-slate-400 font-bold uppercase">Qist Plans</p><p class="font-black text-xl text-blue-600"><%= stats.installments %></p></div>
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-100 text-center"><p class="text-[10px] text-slate-400 font-bold uppercase">Total Inventory</p><p class="font-black text-lg">Rs. <%= stats.totalValue.toLocaleString() %></p></div>
        </div>

        <!-- Use admin specific pagination -->
        <%- include('pagination') %>
    </main>

    <script>
        // Trending Products Chart
        const topNames = <%- JSON.stringify(topProducts.map(p => p.name)) %>;
        const topViews = <%- JSON.stringify(topProducts.map(p => p.views)) %>;

        new Chart(document.getElementById('trendingChart'), {
            type: 'bar',
            data: {
                labels: topNames,
                datasets: [{
                    label: 'Product Views',
                    data: topViews,
                    backgroundColor: '#2563eb',
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true } }
            }
        });

        // Dummy Traffic Chart (Can be linked to date-based analytics later)
        new Chart(document.getElementById('trafficChart'), {
            type: 'line',
            data: {
                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                datasets: [{
                    label: 'Visits',
                    data: [12, 19, 3, 5, 2, 3, <%= (stats.siteVisits % 100) %>],
                    borderColor: '#10b981',
                    tension: 0.4,
                    fill: true,
                    backgroundColor: 'rgba(16, 185, 129, 0.1)'
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } }
            }
        });
    </script>
</body>
</html>