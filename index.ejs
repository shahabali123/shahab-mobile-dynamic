<!DOCTYPE html>
<html lang="en">
<head>
    <title><%= title %></title>
    <%- include('head') %>
</head>
<body class="bg-[#f8fafc] text-slate-900 overflow-x-hidden">
    
    <%- include('nav') %>

    <!-- Hero Section -->
    <header class="container mx-auto px-6 pt-12 pb-8">
        <div class="bg-gradient-to-br from-slate-950 via-slate-900 to-indigo-950 rounded-[3rem] p-8 md:p-20 text-white relative overflow-hidden shadow-[0_35px_60px_-15px_rgba(0,0,0,0.5)] flex flex-col md:flex-row items-center gap-16 border border-white/5">
            <div class="relative z-10 flex-1 text-center md:text-left">
                <div class="flex items-center justify-center md:justify-start gap-3 mb-8">
                    <div class="w-12 h-[1px] bg-indigo-500/50 hidden md:block"></div>
                    <span class="text-indigo-400 text-xs font-black uppercase tracking-[0.5em] drop-shadow-[0_0_10px_rgba(129,140,248,0.5)]"><%= settings.heroBrandName %></span>
                </div>
                <h2 class="text-4xl md:text-6xl lg:text-8xl font-black mb-8 leading-[1.05] tracking-tight">
                    <%- settings.heroTitle %>
                </h2>
                <p class="text-slate-400 text-lg md:text-xl mb-10 max-w-xl leading-relaxed mx-auto md:mx-0 font-medium">
                    <%= settings.heroDescription %>
                </p>
                <div class="flex flex-wrap justify-center md:justify-start gap-5">
                    <a href="<%= settings.heroPrimaryBtnLink %>" class="bg-indigo-600 text-white px-10 py-5 rounded-2xl font-bold hover:bg-indigo-500 transition shadow-2xl shadow-indigo-500/20 hover:-translate-y-1 duration-300">
                        <%= settings.heroPrimaryBtnText %>
                    </a>
                    <a href="<%= settings.heroSecondaryBtnLink %>" class="bg-white/5 border border-white/10 px-10 py-5 rounded-2xl font-bold hover:bg-white/10 transition duration-300 backdrop-blur-md flex items-center gap-3">
                        <%= settings.heroSecondaryBtnText %> <i class="fas fa-arrow-right text-xs text-indigo-400"></i>
                    </a>
                    <a href="<%= settings.heroInstallmentBtnLink %>" class="bg-green-600 text-white px-10 py-5 rounded-2xl font-bold hover:bg-green-500 transition shadow-2xl shadow-green-500/20 hover:-translate-y-1 duration-300 flex items-center gap-3">
                        <i class="fas fa-hand-holding-usd"></i> <%= settings.heroInstallmentBtnText %>
                    </a>
                </div>
            </div>
            
            <div class="relative z-10 flex-1 flex justify-center items-center mt-12 md:mt-0">
                <div class="relative group">
                    <div class="absolute -top-20 -right-20 w-64 h-64 bg-indigo-500/10 rounded-full blur-[100px] animate-pulse"></div>
                    <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-blue-500/10 rounded-full blur-[100px] animate-pulse"></div>
                    <% 
                       let heroImg = settings.heroImage.startsWith('http') ? settings.heroImage : cloudinaryBase + settings.heroImage;
                    %>
                    <img src="<%= heroImg %>" alt="Shahab Mobile Featured" class="relative z-20 w-full max-w-lg h-auto rounded-[3rem] shadow-2xl animate-float-3d border border-white/10">
                </div>
            </div>

            <div class="absolute right-[-10%] bottom-[-10%] opacity-[0.03] text-[20rem] font-black select-none pointer-events-none uppercase tracking-tighter italic whitespace-nowrap">
                <%= settings.heroWatermark %>
            </div>
        </div>
    </header>

    <!-- Floating "Talk to Me" Message Button -->
    <a href="/chat" 
       class="fixed bottom-8 right-8 z-[100] bg-blue-600 text-white w-16 h-16 rounded-full flex items-center justify-center text-3xl shadow-2xl hover:bg-blue-700 hover:-translate-y-2 transition-all duration-300 group">
        <i class="fas fa-comment-dots"></i>
        <span class="absolute right-full mr-4 bg-slate-900 text-white text-xs font-bold px-4 py-2 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">Talk to me! 👋</span>
    </a>

    <main class="container mx-auto p-4">
        <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-6">
            <div class="text-center md:text-left">
                <h2 class="text-3xl font-black text-slate-900">Featured Products</h2>
                <p class="text-slate-500">Hamare behtreen smartphones ka majmua.</p>
            </div>
            
            <!-- Brand Filter -->
            <form action="/" method="GET" class="w-full md:w-64">
                <select name="brand" onchange="this.form.submit()" class="w-full bg-white border border-slate-200 p-3 rounded-xl shadow-sm outline-none focus:ring-2 focus:ring-blue-500 font-bold text-slate-700">
                    <option value="">All Brands</option>
                    <% brands.forEach(b => { %>
                        <option value="<%= b %>" <%= selectedBrand === b ? 'selected' : '' %>><%= b %></option>
                    <% }) %>
                </select>
            </form>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6" id="product-grid">
            <% products.forEach(product => { %>
                <%- include('card', { product: product }) %>
            <% }); %>
        </div>

        <%- include('pagination') %>
    </main>

    <%- include('footer') %>

    <!-- Scripts -->
    <script>
        // Injecting server data to client for Cart/Share logic
        window.products = <%- JSON.stringify(products) %>;
    </script>
    <script src="/app.js"></script>
</body>
</html>