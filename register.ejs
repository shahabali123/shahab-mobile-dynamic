<!DOCTYPE html>
<html lang="en">
<head>
    <title><%= title %></title>
    <%- include('head') %>
</head>
<body class="bg-slate-100 min-h-screen flex flex-col">
    <%- include('nav') %>

    <main class="flex-grow flex items-center justify-center p-4">
        <div class="max-w-md w-full bg-white rounded-[2.5rem] p-8 md:p-12 shadow-xl border border-slate-100">
            <div class="text-center mb-10">
                <h1 class="text-3xl font-black text-slate-900 mb-2">Create Your Account</h1>
                <p class="text-slate-500">Apne orders track karein aur tez checkout karein.</p>
            </div>

            <% if (error) { %>
                <div class="bg-red-50 text-red-600 p-4 rounded-2xl mb-6 text-sm font-bold text-center border border-red-100">
                    <%= error %>
                </div>
            <% } %>

            <form action="/register" method="POST" class="space-y-6">
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase mb-2 ml-2">Full Name</label>
                    <input type="text" name="fullName" required placeholder="Shahab Mughal" class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase mb-2 ml-2">Email Address</label>
                    <input type="email" name="email" required placeholder="your@example.com" class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase mb-2 ml-2">Password</label>
                    <input type="password" name="password" required class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase mb-2 ml-2">Phone Number (Optional)</label>
                    <input type="tel" name="phone" placeholder="03xx xxxxxxx" class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase mb-2 ml-2">Address (Optional)</label>
                    <textarea name="address" rows="2" placeholder="Your full delivery address" class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500"></textarea>
                </div>
                <button type="submit" class="w-full bg-blue-600 text-white py-5 rounded-3xl font-black text-lg hover:bg-blue-700 transition shadow-xl">
                    REGISTER
                </button>
            </form>

            <div class="mt-8 text-center">
                <p class="text-slate-500 text-sm">Already have an account? <a href="/login-customer" class="text-blue-600 font-bold hover:underline">Login here</a></p>
            </div>
        </div>
    </main>

    <%- include('footer') %>
</body>
</html>